# =====================
# Unity 전용 .gitignore
# =====================

# Unity 생성 폴더 (로컬에서 자동 재생성됨)
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# MemoryCaptures (Unity Memory Profiler)
[Mm]emoryCaptures/

# Asset meta data (이 줄은 절대 추가하지 마세요 — meta 파일은 버전관리 필요)
# !/[Aa]ssets/**/*.meta

# Unity Crashes 폴더
[Cc]rashes/

# IL2CPP 빌드 결과물
/[Ii][Ll]2[Cc]pp_[Cc]ache/

# Unity Addressables 빌드 결과물
/[Ss]ervices/
[Aa]ddressables_[Tt]emp/

# =====================
# 에디터 관련
# =====================
.vs/
.vscode/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# JetBrains Rider
.idea/
*.riderproject

# =====================
# OS 관련
# =====================
# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns

# =====================
# Firebase / 환경 설정
# =====================
google-services.json
GoogleService-Info.plist
.env
.env.*
*.keystore
*.jks

# =====================
# 빌드 결과물
# =====================
*.apk
*.aab
*.ipa
*.xcode/
ExportOptions.plist

# =====================
# 대용량 에셋 (필요 시 Git LFS 사용)
# =====================
# 아래 확장자는 Git LFS 대상 (별도 .gitattributes 설정)
# *.psd
# *.fbx
# *.max
# *.blend
